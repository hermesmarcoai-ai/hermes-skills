# Web Search Plus — API Keys Template
# Copy this to .env and fill in your keys
# At least one key is required; more keys = better auto-routing coverage

# Serper (Google Search) — https://serper.dev — 2,500 free/month
SERPER_API_KEY=

# Tavily (Research/Analysis) — https://tavily.com — 1,000 free/month
TAVILY_API_KEY=

# Exa (Neural/Semantic Search) — https://exa.ai — 1,000 free/month
EXA_API_KEY=

# Querit (Multilingual AI Search) — https://querit.ai — 1,000 free/month
QUERIT_API_KEY=

# Perplexity (via Kilo Gateway) — uses KILOCODE_API_KEY if set
# PERPLEXITY_API_KEY=

# You.com — https://api.you.com
# YOU_API_KEY=

# SearXNG (self-hosted, no API key needed — just set your instance URL)
# SEARXNG_INSTANCE_URL=https://your-searxng-instance.example.com
